# Client environment variables (Vite)
# Copy to .env.development / .env.production and adjust as needed.

# Backend API base URL (defaults to /api when unset)
VITE_API_URL=https://uyirproduction.onrender.com

# NOTE: The MSG91 OTP Widget credentials are intentionally hardcoded in
# src/lib/msg91.ts so every environment uses the same production widget.
# There are no MSG91 env vars to configure on the client.
