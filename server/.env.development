# Development Environment Variables Template
# Copy this file to .env for local development:
#   cp .env.development .env
# DO NOT commit .env to git — it is in .gitignore

# Database — Neon PostgreSQL or local
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Server
PORT=4000
NODE_ENV=development

# Development JWT secret (use a strong random secret in production)
JWT_SECRET=dev-jwt-secret-change-in-production

# AI providers (optional for development)
OPENAI_API_KEY=sk-your-openai-key
GEMINI_API_KEY=your-gemini-key
REPLICATE_API_TOKEN=r8-your-replicate-token

# Models
OPENAI_STT_MODEL=whisper-1
OPENAI_TEXT_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-1.5-flash

# MSG91 SMS (OTP)
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_OTP_TEMPLATE_ID=your-msg91-template-id

# Firebase (push notifications)
FIREBASE_SERVICE_ACCOUNT_BASE64=your-firebase-service-account-base64
