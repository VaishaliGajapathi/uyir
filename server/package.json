{
  "name": "uyir-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "prestart": "node -e \"const fs=require('fs'); const path=require('path'); const pub=path.resolve('public'); const dist=path.resolve('../client/dist'); if(!fs.existsSync(pub)&&fs.existsSync(dist)){ try{fs.cpSync(dist,pub,{recursive:true}); console.log('[prestart] Copied client/dist to public/');}catch(e){console.log('[prestart] Copy failed:',e.message);} } else { console.log('[prestart] public/ exists or client/dist missing, skipping copy'); }\"",
    "start": "node dist/index.js",
    "test": "vitest"
  },
  "dependencies": {
    "@fal-ai/client": "^1.10.1",
    "@google/generative-ai": "^0.21.0",
    "@sentry/node": "^10.60.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "firebase-admin": "^13.0.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.77.0",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "replicate": "^1.0.1",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9",
    "web-push": "^3.6.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/web-push": "^3.6.4"
  }
}
