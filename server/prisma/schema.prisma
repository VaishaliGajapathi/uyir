// UYIR — Tamil Nadu Verified Blood & Platelet Emergency Network
// PostgreSQL (Neon cloud database)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(cuid())
  name               String
  mobile             String   @unique
  password           String?
  role               String   @default("donor") // donor | requester | verifier | admin | hospital_approver
  language           String   @default("ta")    // ta | en
  district           String?
  taluk              String?
  bloodGroup         String?
  gender             String?
  age                Int?
  dob                DateTime?
  lastDonationDate   DateTime?
  isPlateletDonor    Boolean  @default(false)
  nightEmergency     Boolean  @default(false)
  shareLocation      Boolean  @default(false)
  lat                Float?
  lng                Float?
  reputationScore    Int      @default(0)
  donationCount      Int      @default(0)
  verified           Boolean  @default(false)
  banned             Boolean  @default(false)
  fcmToken           String?
  createdAt          DateTime @default(now())

  // Notification preferences
  notificationsEnabled Boolean  @default(true)
  voiceEnabled         Boolean  @default(true)
  locationEnabled      Boolean  @default(true)

  // Health fields for donors
  hemoglobinLevel    Float?
  drinkingHabits     String?  // never | occasional | regular
  smokingHabits      String?  // never | occasional | regular
  sleepHours         Int?
  healthTips         String?
  weight             Float?   // in kg
  height             Float?   // in cm

  // Hospital approver fields
  hospitalName       String?
  hospitalRegistrationId String?
  hospitalId         String?

  requests           BloodRequest[]  @relation("CreatedRequests")
  responses          DonorResponse[]
  badges             DonorBadge[]
  fraudReportsFiled  FraudReport[]   @relation("ReportedBy")
  fraudReportsAgainst FraudReport[]  @relation("AgainstUser")
  documents          DonorDocument[]
  hospital           Hospital?       @relation(fields: [hospitalId], references: [id])
  ratingsGiven       DonationRating[] @relation("GivenRatings")
  ratingsReceived    DonationRating[] @relation("ReceivedRatings")
  healthReminders    HealthReminder[]
}

model Hospital {
  id        String   @id @default(cuid())
  name      String
  district  String
  address   String?
  phone     String?
  lat       Float?
  lng       Float?
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  requests  BloodRequest[]
  approvers User[]
}

model BloodRequest {
  id                String   @id @default(cuid())
  patientName       String
  patientAge        Int?
  patientGender     String?
  bloodGroup        String
  componentType     String   @default("whole_blood") // whole_blood | platelets | plasma
  unitsRequired     Int      @default(1)
  hospitalId        String?
  hospitalName      String
  district          String
  taluk             String?
  lat               Float?
  lng               Float?
  contactPerson     String
  contactNumber     String
  doctorReference   String?
  emergencyLevel    String   @default("orange") // green | orange | red
  status            String   @default("pending_verification") // draft|pending_verification|verified|alert_sent|donor_accepted|completed|closed|rejected|life_saved
  verificationScore Int      @default(0)
  verificationNotes String?
  alertRadiusKm     Int      @default(25)
  escalationLevel   Int      @default(0) // 0=initial, 1=expanded, 2=district-wide
  escalatedAt       DateTime?
  createdById       String
  createdAt         DateTime @default(now())
  closedAt          DateTime?

  // Verification tracking
  verifiedBy        String?
  verifiedByType    String?  // uyir_admin | hospital_approver
  verifiedAt        DateTime?

  hospital   Hospital?       @relation(fields: [hospitalId], references: [id])
  createdBy  User            @relation("CreatedRequests", fields: [createdById], references: [id])
  documents  RequestDocument[]
  responses  DonorResponse[]
  alerts     AlertLog[]
  ratings    DonationRating[]
}

model RequestDocument {
  id            String   @id @default(cuid())
  requestId     String
  fileUrl       String
  documentType  String   @default("requirement_slip") // requirement_slip | prescription
  aiVerified    Boolean  @default(false)
  aiScore       Int      @default(0)
  aiNotes       String?
  uploadedAt    DateTime @default(now())
  request       BloodRequest @relation(fields: [requestId], references: [id])
}

model DonorResponse {
  id          String    @id @default(cuid())
  requestId   String
  donorId     String
  status      String    @default("alerted") // alerted | accepted | declined | arrived | completed
  matchScore  Int       @default(0)
  distanceKm  Float?
  etaMinutes  Int?
  acceptedAt  DateTime?
  arrivedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  // Detailed donation tracking
  navigationStarted DateTime?
  personMet        DateTime?
  donationStarted   DateTime?
  trackingNotes     String?

  // Real-time location tracking for ETA
  currentLat        Float?
  currentLng        Float?
  lastLocationUpdate DateTime?
  estimatedArrival  DateTime?

  request BloodRequest @relation(fields: [requestId], references: [id])
  donor   User         @relation(fields: [donorId], references: [id])

  @@unique([requestId, donorId])
}

model DonorBadge {
  id          String   @id @default(cuid())
  donorId     String
  badgeName   String
  awardedDate DateTime @default(now())
  donor       User     @relation(fields: [donorId], references: [id])
}

model FraudReport {
  id           String   @id @default(cuid())
  againstUserId String
  reportedById String?
  requestId    String?
  reason       String
  aiFlag       String?  // ai-detected category
  aiConfidence Int      @default(0)
  status       String   @default("open") // open | reviewing | actioned | dismissed
  createdAt    DateTime @default(now())

  againstUser User  @relation("AgainstUser", fields: [againstUserId], references: [id])
  reportedBy  User? @relation("ReportedBy", fields: [reportedById], references: [id])
}

model AlertLog {
  id        String   @id @default(cuid())
  requestId String
  radiusKm  Int
  donorCount Int     @default(0)
  channel   String   @default("push") // push | whatsapp
  createdAt DateTime @default(now())
  request   BloodRequest @relation(fields: [requestId], references: [id])
}

model OtpCode {
  id        String   @id @default(cuid())
  mobile    String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model DonorDocument {
  id          String   @id @default(cuid())
  donorId     String
  documentType String  // aadhar | driving_license | passport
  fileUrl     String
  documentNumber String?
  verified    Boolean  @default(false)
  aiVerified  Boolean  @default(false)
  aiScore     Int      @default(0)
  aiNotes     String?
  uploadedAt  DateTime @default(now())
  donor       User     @relation(fields: [donorId], references: [id])
}

model DonationRating {
  id            String   @id @default(cuid())
  requestId     String
  donorId       String
  requesterId   String
  rating        Int      // 1-5 stars
  testimonial   String?
  responseId    String
  createdAt     DateTime @default(now())

  request   BloodRequest @relation(fields: [requestId], references: [id])
  donor     User         @relation("ReceivedRatings", fields: [donorId], references: [id])
  requester User         @relation("GivenRatings", fields: [requesterId], references: [id])
}

model HealthReminder {
  id                String   @id @default(cuid())
  donorId           String
  donationDate      DateTime
  hoursAfterDonation Int
  message           String
  fluidType         String
  foodRecommendation String
  sleepRecommendation String
  scheduledAt       DateTime
  sent              Boolean  @default(false)
  sentAt            DateTime?
  createdAt         DateTime @default(now())

  donor User @relation(fields: [donorId], references: [id])
}
