# Environment Variables Template
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
# DO NOT commit .env to git — it is already in .gitignore

# ============ Database — Neon PostgreSQL ============
# Get from: https://console.neon.tech/
# Use the pooled connection string for production (Neon provides both)
# Format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# ============ Server ============
PORT=3000
NODE_ENV=production

# Generate a strong random secret: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-here

# ============ Redis — Upstash ============
# Get from: https://console.upstash.com/
# Used for: caching, rate limiting, BullMQ job queues
REDIS_URL=rediss://default:PASSWORD@HOST.upstash.io:6379

# ============ Cloudflare R2 (Document Storage) ============
# Get from: https://dash.cloudflare.com/ > R2
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=uyir-documents
R2_PUBLIC_URL=https://docs.yourdomain.com

# ============ AI Providers (optional) ============
# Get keys from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here
# Get keys from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-key-here
# Get keys from: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8-your-replicate-token-here

# Models
OPENAI_STT_MODEL=whisper-1
OPENAI_TEXT_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-1.5-flash

# ============ MSG91 (OTP/SMS) ============
# OTP send/verify happens client-side via the MSG91 OTP Widget. The server
# only validates the widget access token using this auth key.
# Get from: https://msg91.com/ (Server-Side Integration > Get Authkey)
MSG91_AUTH_KEY=your-msg91-auth-key

# ============ Firebase Cloud Messaging (FCM) ============
# Get from: https://console.firebase.google.com/
# 1. Create a service account key (JSON) from Project Settings > Service Accounts
# 2. Base64 encode it: base64 -i service-account.json
# 3. Paste the base64 string here
FIREBASE_SERVICE_ACCOUNT_BASE64=your-base64-encoded-firebase-service-account-json

# ============ Web Push Notifications (VAPID keys) ============
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=BN2qX9pwoJchmWAKnVNfea2ZmyIjCon4cIEuXKnk6CxfrbG14nwoOGp2VJWlj5AgwAVikn8FRmlmFRynZZXHLvA
VAPID_PRIVATE_KEY=rJHWoeyruRL1uoQVnbL1kgmgQN_ov8bNj5GE23nvup8

# ============ Sentry (Error Tracking, optional) ============
# Get from: https://sentry.io/
SENTRY_DSN=

# ============ Worker Concurrency ============
NOTIFICATION_WORKER_CONCURRENCY=3
DOCUMENT_WORKER_CONCURRENCY=2
AI_WORKER_CONCURRENCY=2
