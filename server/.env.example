# Database — SQLite locally; swap to Postgres URL on Render
DATABASE_URL="file:./prisma/dev.db"

# Server
PORT=4000
JWT_SECRET=change-this-secret

# AI providers (real calls)
OPENAI_API_KEY=
GEMINI_API_KEY=
REPLICATE_API_TOKEN=

# Models (override if needed)
OPENAI_STT_MODEL=whisper-1
OPENAI_TEXT_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-1.5-flash

# Twilio SMS (for real OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
