# Environment Variables Template
# Copy the appropriate file to .env:
# - For development: cp .env.development .env
# - For production: cp .env.production .env

# Database — Neon PostgreSQL (cloud-hosted)
DATABASE_URL="postgresql://neondb_owner:npg_XgxUrpMav63i@ep-patient-meadow-ao7vvott-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Server
PORT=4000
NODE_ENV=development
JWT_SECRET=uyir-dev-secret

# AI providers
# Get keys from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
# Get keys from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
# Get keys from: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8-your-replicate-token-here

# Models
OPENAI_STT_MODEL=whisper-1
OPENAI_TEXT_MODEL=gpt-4o
GEMINI_MODEL=gemini-1.5-flash

# MSG91 SMS (for OTP - India, much cheaper than Twilio)
# Get from: https://msg91.com/
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_OTP_TEMPLATE_ID=your-msg91-template-id

# Firebase Cloud Messaging (FCM) for native donor push notifications
# Get from: https://console.firebase.google.com/
# Download service account JSON and base64-encode it, then set below
FIREBASE_SERVICE_ACCOUNT_BASE64=your-base64-encoded-firebase-service-account-json
