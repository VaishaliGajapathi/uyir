# Production Environment Variables Template
# Copy this file to .env and fill in your real values:
#   cp .env.production .env
# DO NOT commit .env to git — it is in .gitignore

# Database — Neon PostgreSQL or your provider
# Format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Server
PORT=3000
NODE_ENV=production

# Generate a strong random secret: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-here

# AI providers (optional)
OPENAI_API_KEY=sk-your-openai-key
GEMINI_API_KEY=your-gemini-key
REPLICATE_API_TOKEN=r8-your-replicate-token

# Models
OPENAI_STT_MODEL=whisper-1
OPENAI_TEXT_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-1.5-flash

# MSG91 SMS (OTP)
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_OTP_TEMPLATE_ID=your-msg91-template-id

# Firebase (push notifications)
FIREBASE_SERVICE_ACCOUNT_BASE64=your-firebase-service-account-base64

# Twilio (backup SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+91XXXXXXXXXX
